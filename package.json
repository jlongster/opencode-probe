{
  "$schema": "https://json.schemastore.org/package.json",
  "name": "opencode-drive",
  "version": "0.5.0",
  "description": "Drive real and simulated OpenCode instances",
  "license": "MIT",
  "type": "module",
  "packageManager": "bun@1.3.14",
  "bin": {
    "opencode-drive": "bin/opencode-drive"
  },
  "exports": {
    ".": "./src/index.ts",
    "./client": "./src/client/index.ts",
    "./driver": "./src/driver/index.ts",
    "./experimental": "./src/experimental/index.ts",
    "./llm": "./src/llm/index.ts",
    "./recording": "./src/recording/index.ts",
    "./script": "./src/script/index.ts"
  },
  "files": [
    "assets/fonts",
    "bin/opencode-drive",
    "src/cli",
    "src/client",
    "src/driver",
    "src/experimental",
    "src/instance",
    "src/llm",
    "src/log.ts",
    "src/recording",
    "src/script",
    "src/simulation",
    "src/index.ts",
    "README.md"
  ],
  "scripts": {
    "drive": "bun run src/cli/index.ts",
    "lint": "oxlint src",
    "test": "bun run test:effect && bun run test:cli",
    "test:effect": "bun run --bun vitest run",
    "test:cli": "bun test test/cli/integration.test.ts",
    "typecheck": "tsgo --noEmit",
    "check": "bun run lint && bun run typecheck"
  },
  "dependencies": {
    "@effect/platform-node": "4.0.0-beta.98",
    "@effect/platform-node-shared": "4.0.0-beta.98",
    "@fontsource/noto-sans-symbols-2": "5.2.8",
    "@napi-rs/canvas": "1.0.2",
    "@wterm/core": "0.3.0",
    "@wterm/ghostty": "0.3.0",
    "effect": "4.0.0-beta.98"
  },
  "devDependencies": {
    "@effect/vitest": "4.0.0-beta.98",
    "@tsconfig/bun": "1.0.9",
    "@types/bun": "1.3.13",
    "@typescript/native-preview": "7.0.0-dev.20251207.1",
    "oxlint": "1.60.0",
    "oxlint-tsgolint": "0.21.0",
    "typescript": "5.8.2",
    "vitest": "4.1.10"
  }
}
